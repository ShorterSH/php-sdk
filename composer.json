{
  "name": "shorter/sdk",
  "description": "PHP SDK for the shorter.sh URL shortener",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "ShorterSH",
      "homepage": "https://shorter.sh"
    }
  ],
  "homepage": "https://shorter.sh",
  "support": {
    "issues": "https://github.com/ShorterSH/php-sdk/issues",
    "source": "https://github.com/ShorterSH/php-sdk"
  },
  "keywords": [
    "url-shortener",
    "link-shortener",
    "short-url",
    "shorter.sh",
    "sdk"
  ],
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "autoload": {
    "psr-4": { "Shorter\\Sdk\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Shorter\\Sdk\\Tests\\": "tests/" }
  }
}
